        "title": "Multiple Destination Support",
        "text": "Send data to multiple endpoints simultaneously with independent configuration"
      },
      "association": {
        "title": "Asset Association",
        "text": "Link assets to routing groups to control their data flow and destinations"
      },
      "control": {
        "title": "Enable/Disable Control",
