{
  "$schema": "mapex-plugin",
  "pluginId": "discord",
  "name": "Discord",
  "description": "Send messages, embeds and manage channels via Discord API",
  "enabled": true,
  "version": "1.0.0",
  "category": "messaging",
  "icon": "forum",
  "color": "#5865F2",
  "author": "Mapex Solutions",
  "tags": [
    "messaging",
    "chat",
    "notifications",
    "community"
  ],
  "defaults": {
    "baseUrl": "https://discord.com/api/v10",
    "timeout": 30000
  },
  "metadata": {
    "brandIcon": "discord/icon.svg",
    "color": "#5865F2",
    "docs": "https://discord.com/developers/docs"
  },
  "credentials": [
    {
      "id": "discordWebhook",
      "name": "Discord Webhook",
      "fields": [
        {
          "name": "webhookUrl",
          "displayName": "Webhook URL",
          "type": "string",
          "required": true,
          "isSecret": true,
          "hint": "From Discord → Channel Settings → Integrations → Webhooks"
        }
      ],
      "type": "manual"
    },
    {
      "id": "discordBot",
      "name": "Discord Bot Token",
      "fields": [
        {
          "name": "botToken",
          "displayName": "Bot Token",
          "type": "string",
          "required": true,
          "isSecret": true,
          "hint": "From Discord Developer Portal → Bot → Token"
        }
      ],
      "test": {
        "type": "http",
        "http": {
          "method": "GET",
          "path": "/users/@me"
        }
      },
      "type": "manual"
    }
  ],
  "fetchOptions": {
    "getGuilds": {
      "type": "http",
      "http": {
        "method": "GET",
        "path": "/users/@me/guilds",
        "headers": {
          "Authorization": "Bot {{credentials.botToken}}"
        }
      },
      "output": {
        "transform": "function transform(data) { return data.map(function(g) { return { label: g.name, value: g.id }; }); }"
      }
    },
    "getChannels": {
      "type": "http",
      "http": {
        "method": "GET",
        "path": "/guilds/{{dependsOn.guildId}}/channels",
        "headers": {
          "Authorization": "Bot {{credentials.botToken}}"
        }
      },
      "output": {
        "transform": "function transform(data) { return data.filter(function(c) { return c.type === 0; }).map(function(c) { return { label: '#' + c.name, value: c.id }; }); }"
      }
    }
  },
  "nodeTypes": [
    {
      "type": "discord/message",
      "label": "Discord Message",
      "icon": "forum",
      "color": "#5865F2",
      "description": "Send and manage messages in Discord channels",
      "timeout": {
        "duration": 30,
        "unit": "seconds",
        "enableOutput": false
      },
      "inputs": [
        {
          "id": "in",
          "label": "In",
          "position": "top"
        }
      ],
      "outputs": [
        {
          "id": "success",
          "label": "Success",
          "position": "bottom",
          "color": "#4caf50"
        },
        {
          "id": "error",
          "label": "Error",
          "position": "bottom",
          "color": "#ef5350"
        }
      ],
      "properties": [
        {
          "name": "operation",
          "displayName": "Operation",
          "type": "options",
          "default": "sendText",
          "options": [
            {
              "label": "Send Text",
              "value": "sendText"
            },
            {
              "label": "Send Embed",
              "value": "sendEmbed"
            },
            {
              "label": "Edit Message",
              "value": "editMessage"
            },
            {
              "label": "Delete Message",
              "value": "deleteMessage"
            }
          ]
        },
        {
          "name": "channelId",
          "displayName": "Channel ID",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": ""
          },
          "required": true,
          "allowedSources": [
            "fetchOptions",
            "literal",
            "state",
            "event",
            "nodeOutput"
          ],
          "fetchOptions": {
            "rules": [
              {
                "when": {},
                "key": "getChannels",
                "label": "Search Channels"
              }
            ]
          },
          "hint": "Discord channel ID"
        },
        {
          "name": "text",
          "displayName": "Content",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": ""
          },
          "required": true,
          "rendering": {
            "multiline": true,
            "rows": 4
          },
          "displayOptions": {
            "show": {
              "operation": [
                "sendText"
              ]
            }
          }
        },
        {
          "name": "embedTitle",
          "displayName": "Embed Title",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": ""
          },
          "required": true,
          "displayOptions": {
            "show": {
              "operation": [
                "sendEmbed"
              ]
            }
          }
        },
        {
          "name": "embedDescription",
          "displayName": "Embed Description",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": ""
          },
          "required": true,
          "rendering": {
            "multiline": true,
            "rows": 4
          },
          "displayOptions": {
            "show": {
              "operation": [
                "sendEmbed"
              ]
            }
          }
        },
        {
          "name": "embedColor",
          "displayName": "Embed Color",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": "5793266"
          },
          "hint": "Decimal color value (e.g., 5793266 for blue)"
        },
        {
          "name": "embedUrl",
          "displayName": "Embed URL",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": ""
          },
          "hint": "URL linked from embed title",
          "displayOptions": {
            "show": {
              "operation": [
                "sendEmbed"
              ]
            }
          }
        },
        {
          "name": "messageId",
          "displayName": "Message ID",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": ""
          },
          "required": true,
          "displayOptions": {
            "show": {
              "operation": [
                "editMessage",
                "deleteMessage"
              ]
            }
          }
        },
        {
          "name": "newText",
          "displayName": "New Content",
          "type": "fieldSource",
          "default": {
            "type": "literal",
            "value": ""
          },
          "required": true,
          "rendering": {
            "multiline": true,
            "rows": 4
          },
          "displayOptions": {
            "show": {
              "operation": [
                "editMessage"
              ]
            }
          }
        },
        {
          "name": "tts",
          "displayName": "Text-to-Speech",
          "type": "boolean",
          "default": false,
          "displayOptions": {
            "show": {
              "operation": [
                "sendText"
              ]
            }
          }
        }
      ],
      "operations": {
        "sendText": {
          "type": "http",
          "http": {
            "method": "POST",
            "path": "{{manifest.defaults.baseUrl}}/channels/{{config.channelId}}/messages",
            "headers": {
              "Authorization": "Bot {{credentials.botToken}}",
              "Content-Type": "application/json"
            },
            "body": {
              "content": "{{config.text}}",
              "tts": "{{config.tts}}"
            }
          },
          "output": {
            "dataPath": ""
          }
        },
        "sendEmbed": {
          "type": "http",
          "http": {
            "method": "POST",
            "path": "{{manifest.defaults.baseUrl}}/channels/{{config.channelId}}/messages",
            "headers": {
              "Authorization": "Bot {{credentials.botToken}}",
              "Content-Type": "application/json"
            },
            "body": {
              "embeds": [
                {
                  "title": "{{config.embedTitle}}",
                  "description": "{{config.embedDescription}}",
                  "color": "{{config.embedColor}}",
                  "url": "{{config.embedUrl}}"
                }
              ]
            }
          },
          "output": {
            "dataPath": ""
          }
        },
        "editMessage": {
          "type": "http",
          "http": {
            "method": "PATCH",
            "path": "{{manifest.defaults.baseUrl}}/channels/{{config.channelId}}/messages/{{config.messageId}}",
            "headers": {
              "Authorization": "Bot {{credentials.botToken}}",
              "Content-Type": "application/json"
            },
            "body": {
              "content": "{{config.newText}}"
            }
          },
          "output": {
            "dataPath": ""
          }
        },
        "deleteMessage": {
          "type": "http",
          "http": {
            "method": "DELETE",
            "path": "{{manifest.defaults.baseUrl}}/channels/{{config.channelId}}/messages/{{config.messageId}}",
            "headers": {
              "Authorization": "Bot {{credentials.botToken}}"
            }
          },
          "output": {
            "dataPath": ""
          }
        }
      },
      "availableOutputs": [
        {
          "path": "id",
          "description": "ID of the sent message"
        },
        {
          "path": "channel_id",
          "description": "Channel ID"
        },
        {
          "path": "timestamp",
          "description": "ISO8601 timestamp"
        },
        {
          "path": "author.username",
          "description": "Author username"
        },
        {
          "path": "content",
          "description": "Text content of the sent message"
        }
      ],
      "errorHandler": {
        "enabled": false,
        "maxAttempts": 3,
        "initialInterval": 5,
        "intervalUnit": "seconds",
        "backoffMultiplier": 2.0
      }
    }
  ]
}
