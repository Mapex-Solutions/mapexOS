{
  "name": "@mapexos/apis",
  "version": "0.0.1",
  "description": "API Wrappers tools",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "files": [
    "lib/"
  ],
  "scripts": {
    "prebuild": "rimraf lib",
    "prepublishOnly": "npm run test && npm run build",
    "build": "tsc -p tsconfig.json && resolve-tspaths && tsc -p tsconfig-cjs.json && resolve-tspaths -p tsconfig-cjs.json",
    "build:all": "npm run build && typedoc",
    "build:mjs": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig-cjs.json",
    "build:docs": "typedoc",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://github.com/Mapex-Solutions/MapexOS",
    "directory": "packages/apis"
  },
  "keywords": [
    "apis"
  ],
  "author": "thiagoo.anselmoo@gmail.com",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Mapex-Solutions/MapexOS/workspace-js/packages/apis/README.md",
  "dependencies": {
    "rimraf": "^6.0.1",
    "lodash": "^4.18.1",
    "axios": "^1.16.1",
    "dayjs": "1.11.13",
    "@mapexos/schemas": "0.0.1",
    "@mapexos/validations": "0.0.1"
  }
}
