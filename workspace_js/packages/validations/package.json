    "build:all": "npm run build && typedoc",
    "build:mjs": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig-cjs.json",
    "build:docs": "typedoc",
    "test": "jest --runInBand"
  },
  "repository": {
    "type": "git",
