  "homepage": "https://github.com/Mapex-Solutions/MapexOS/workspace-js/packages/validations/README.md",
  "dependencies": {
    "rimraf": "^6.0.1",
    "zod": "4.1.8",
    "dayjs": "1.11.13"
  }
