  "module": "./lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "files": [
    "lib/"
  ],
  "scripts": {
    "prebuild": "rimraf lib",
    "prepublishOnly": "npm run test && npm run build ",
